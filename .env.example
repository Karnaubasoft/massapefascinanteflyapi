# App
NODE_ENV=production
PORT=3000
PORTFRONT=https://massapefascinante.karnaubasoft.com.br

# JWT
JWT_SECRET=sua_chave_secreta_aqui

# Database (Postgres)
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco
