DATABASE_PASS=senha
DATABASE_DB=nome_do_banco

# Redis
REDIS_URL=redis://localhost:6379

# Google OAuth
GOOGLE_CLIENT_ID=seu_google_client_id.apps.googleusercontent.com

# Gmail (SMTP)
GMAIL_USER=seu@gmail.com
PASSWORD_GMAIL=sua_senha_de_app_gmail
